APP_NAME=Rafiq
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/rafeeq/public
PAY_FOR_LATER_ENABLED=true
# Comma-separated OAuth client IDs whose tokens the server will accept.
# Apple native apps usually use the iOS bundle ID as the token aud claim.
GOOGLE_CLIENT_IDS=
APPLE_CLIENT_IDS=
APPLE_BUNDLE_ID=
FIREBASE_PROJECT_ID=rafiq-179b5
FIREBASE_SERVICE_ACCOUNT_JSON=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rafeeq
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ─── AI Provider ───────────────────────────────────────────────────────────────
AI_PROVIDER=openai
AI_EMBEDDING_PROVIDER=openai
AI_CHAT_MODEL=gpt-5.6-sol
AI_EMBEDDING_MODEL=text-embedding-3-large
AI_EMBEDDING_DIMENSIONS=1536
AI_EMBEDDING_BATCH_SIZE=64
AI_EMBEDDING_REQUEST_TIMEOUT=180
AI_DOMAIN_GUARD_ENABLED=true
AI_DOMAIN_GUARD_MODEL=gpt-5.6-luna
AI_DOMAIN_GUARD_CONFIDENCE=0.85
AI_EMBEDDING_CONNECT_TIMEOUT=15
AI_DOCUMENT_CHUNK_WORDS=420
AI_DOCUMENT_CHUNK_OVERLAP_WORDS=60
AI_DOCUMENT_CHUNK_MAX_BYTES=7500
AI_DOCUMENT_EXTRACTION_COMMAND_TIMEOUT=900
AI_PDF_PARSER_MAX_BYTES=15728640
AI_OCR_LANGUAGES=ara+eng
AI_OCR_MAX_PAGES=600
AI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
AI_TRANSCRIPTION_SEGMENT_SECONDS=1200
AI_DOCUMENT_VISION_MODEL=gpt-5.6-luna
AI_DOCUMENT_VISION_DETAIL=high
AI_DOCUMENT_VISION_FILL_SPARSE_PAGES=true
AI_DOCUMENT_SPARSE_PAGE_CHARACTERS=80
AI_VIDEO_FRAME_INTERVAL_SECONDS=60
AI_VIDEO_MAX_FRAMES=12
AI_DOCUMENT_EXTRACTION_CACHE=true
AI_CONSENT_VERSION=1.0
AI_PROVIDER_NAME=OpenAI
PRIVACY_POLICY_URL=

# ─── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Gemini (optional) ─────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── Anthropic (optional) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Web Search (optional) ─────────────────────────────────────────────────────
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=brave
BRAVE_API_KEY=
SERPAPI_API_KEY=

# ─── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@rafiq.app"
MAIL_FROM_NAME="${APP_NAME}"

# ─── AWS S3 (optional) ─────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Pusher (optional) ─────────────────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1
